{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-v-in-tag": true,
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "yaml",
          "path": "charts/tero-edge/Chart.yaml",
          "jsonpath": "$.appVersion"
        }
      ]
    },
    "charts/tero-edge": {
      "release-type": "helm",
      "package-name": "tero-edge-chart"
    }
  }
}
