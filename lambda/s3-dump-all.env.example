# =============================================================================
# Sample: dump every Datadog log to S3 from the Lambda extension
# =============================================================================
#
# A complete, copy-pasteable configuration for the `com.usetero/s3-dump`
# extension on Lambda. Set these as the Lambda function's environment variables
# (console, `template.yaml`, or the `environment:` block in docker-compose.yml).
#
# The extension is inert unless BOTH of these are true:
#   1. it is enabled with at least one target (the TERO_S3_DUMP_* vars), AND
#   2. a loaded policy carries a `com.usetero/s3-dump` extension that references
#      that target by name (the TERO_POLICY_STATIC policy below).
# Env config alone does nothing without the policy, and vice versa.
#
# Requires policy-zig >= v0.6.0 (static policies can carry extensions).

# --- Datadog forwarding (unchanged by s3-dump; logs still flow to Datadog) ----
TERO_LISTEN_PORT=3000
TERO_UPSTREAM_URL=https://http-intake.logs.us5.datadoghq.com
TERO_LOGS_URL=https://http-intake.logs.us5.datadoghq.com
TERO_METRICS_URL=https://api.datadoghq.com
TERO_LOG_LEVEL=info

# --- s3-dump extension: enable + declare the destination bucket ---------------
# Targets are a JSON array because zonfig can't express a slice-of-struct from a
# plain env var. `name` is what the policy references; only `name`+`bucket` are
# required. Drop `endpoint`/set force_path_style=true for MinIO/R2.
TERO_S3_DUMP_ENABLED=true
TERO_S3_DUMP_TARGETS_JSON=[{"name":"datadog-forwarder-dump","bucket":"my-datadog-dump-bucket","region":"us-east-1","prefix":"datadog/","endpoint":"https://s3.us-east-1.amazonaws.com","force_path_style":false}]

# --- The policy that routes records to the target -----------------------------
# One log policy matching every record (body =~ .*; the spec forbids an empty
# match list) with an s3-dump extension in mode "all" — so KEPT, DROPPED, and
# UNMATCHED records are all dumped. `keep: "all"` keeps forwarding to Datadog
# too; use `keep: "none"` to dump-and-drop (S3 only, nothing to Datadog).
# The extension's target `name` must equal a target in TERO_S3_DUMP_TARGETS_JSON.
# Must be a single line (no newlines) — it's one env var.
TERO_POLICY_STATIC={"policies":[{"id":"dump-all","name":"Dump all logs to S3","enabled":true,"log":{"match":[{"log_field":"body","regex":".*"}],"keep":"all"},"extensions":[{"type":"com.usetero/s3-dump","version":"1.0.0","mode":"all","target":{"kind":"s3","name":"datadog-forwarder-dump"}}]}]}

# --- Credentials --------------------------------------------------------------
# Preferred on Lambda: nothing to set here — the execution role's own creds
# (reserved AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY/AWS_SESSION_TOKEN) are used
# directly; the signer sends x-amz-security-token. Just give the role
# s3:PutObject on the bucket.
#
# Only if you need a static IAM-user keypair instead (e.g. cross-account), set
# the TERO_S3_* names, which the runtime never overwrites:
# TERO_S3_ACCESS_KEY_ID=AKIA...
# TERO_S3_SECRET_ACCESS_KEY=...
# TERO_S3_SESSION_TOKEN=...          # only if that keypair is itself temporary
